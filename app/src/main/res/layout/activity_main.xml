<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <Button
        android:layout_width="120pt"
        android:layout_height="30pt"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginBottom="150pt"
        android:text="Averías Reportadas"
        android:id="@+id/repor"/>


    <Button
        android:layout_width="120pt"
        android:layout_height="30pt"
        app:layout_constraintTop_toBottomOf="@id/repor"
        app:layout_constraintStart_toStartOf="@id/repor"
        android:layout_marginTop="50pt"
        android:text="Averías en proceso"
        android:id="@+id/proces"
        />

    <Button
        android:layout_width="120pt"
        android:layout_height="30pt"
        app:layout_constraintTop_toBottomOf="@id/proces"
        app:layout_constraintStart_toStartOf="@id/proces"
        android:layout_marginTop="50pt"
        android:text="Averías finalizadas"
        android:id="@+id/fin"
        />




</androidx.constraintlayout.widget.ConstraintLayout>