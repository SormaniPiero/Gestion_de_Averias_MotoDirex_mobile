<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Login">
  
  
  <TextView
      android:layout_width="90pt"
      android:textSize="17pt"
      android:layout_height="wrap_content"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    app:layout_constraintRight_toRightOf="parent"
    android:text="Motodirex"
      android:layout_marginTop="30pt"
      android:id="@+id/titulo"
    />
  
  <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
    app:layout_constraintTop_toBottomOf="@id/titulo"
    app:layout_constraintStart_toStartOf="@id/titulo"
   
      android:layout_marginTop="30pt"
      android:textSize="10pt"
    android:text="E-mail"
      android:id="@+id/mailTitulo"
      />
  
  <EditText
      android:layout_width="90pt"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@id/mailTitulo"
      app:layout_constraintStart_toStartOf="@id/mailTitulo"
      android:id="@+id/etMail"
      />
  
  <TextView
      android:layout_width="wrap_content"
      android:textSize="10pt"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@id/etMail"
      app:layout_constraintStart_toStartOf="@id/etMail"
      android:layout_marginTop="10pt"
      android:text="Contraseña"
      android:id="@+id/contrasenyaTit"
      />
  

  
  <EditText
      android:layout_width="90pt"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@id/contrasenyaTit"
      app:layout_constraintStart_toStartOf="@id/contrasenyaTit"
      android:id="@+id/etContrasenya"/>
  
  <Button
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      app:layout_constraintTop_toBottomOf="@+id/etContrasenya"
    app:layout_constraintStart_toStartOf="@id/etContrasenya"
    app:layout_constraintEnd_toEndOf="@id/etContrasenya"
    android:text="Acceder"
    android:layout_marginTop="30pt"
      android:id="@+id/btnAcceder"
      />

  </androidx.constraintlayout.widget.ConstraintLayout>